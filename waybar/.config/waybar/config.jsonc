{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    // "height": 40, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/vpn", "network", "battery", "pulseaudio#microphone", "pulseaudio", "backlight"],
    // Modules configuration
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon} {windows}",
        "format-window-separator": " ",
	    "window-rewrite-default": "´üÖ ",
	    "window-rewrite": {
	      "title<.*youtube.*>": "´à¬ ",
	      "title<.*amazon.*>": "´ë░ ",
          "title<.*reddit.*>": "´èü ",
          "title<.*Picture-in-Picture.*>": "´ö¼ ",
	      "class<firefox>": "´ë® ",
          "class<kitty>": "´äá ",
          "class<com.mitchellh.ghostty>": "´äá ",
          "class<WebApp-ChatGPT0190>": "¾▒£© ",
          "class<WebApp-iCloud1336>": "¯£æ ",
          "class<obsidian>": "¾▒ôº ",
          "class<konsole>": "´äá ",
          "class<thunar>": "¾░Ø░ ",
          "class<discord>": "´ÄÆ ",
          "class<subl>": "¾░à│ ",
          "class<celluloid>": "´Ç¢ ",
          "class<Cider>": "¾░Äå ",
          "class<code-oss>": "¾░¿× ",
          "class<codeblocks>": "¾░à® ",
          "class<org.larusstone.qtspim>": "´Æ│ ",
          "class<libreoffice-writer>": "¯ÜÑ ",
          "class<libreoffice-startcenter>": "¾░Åå ",
		  "class<mpv>": "´Ç¢ "
	    }   
    },
    "hyprland/window": {
        "format": "{title}",
	    "separate-outputs": true
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´é£"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´ïÆ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "format": "¾░úç  {:%H:%M}",
        "format-alt": "{:%A  |  %H:%M  |  %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "format": "{usage}% ´ïø",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ´âë"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Ø½ ", "´ïë", "´Ø® "]
    },
    "backlight": {
        "device": "acpi_video0",
        "format": "{percent}%  {icon} ",
	    "format-icons": ["¾░ø®", "¾▒®Ä", "¾▒®Å", "¾▒®É", "¾▒®æ", "¾▒®Æ", "¾▒®ô", "¾▒®ö", "¾▒®ò", "¾▒®û", "¾░ø¿"],
        "on-scroll-up": "brightnessctl --device=acpi_video0 set 1%+",
        "on-scroll-down": "brightnessctl --device=acpi_video0 set 1%-",
        "on-click": "brightnessctl --device-acpi_video0 set 50",
        "min-length": 6,
        "scroll-step": 0.5,
        "reverse-scrolling": true,
        "tooltip": false
    },
    "battery": {
        "bat": "BAT0",
	    "states": {
            "good": 85,
            "warning": 40,
            "critical": 20
        },
        "format": "{capacity}%  {icon}",
        "format-charging": "{capacity}%  ¾░éä",
        "format-plugged": "{capacity}% ¾░ÜÑ",
        "format-alt": "{time}  {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "]
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{icon}   {signalStrength}%",
        "format-ethernet": "¾░êÇ  Ethernet",
        "tooltip": false,
        "format-linked": "¾░ñ¡  {ifname} | No IP",
        "format-disconnected": "¾░ñ¡   Disconnected",
        "format-alt": "{icon}   {essid} | {ipaddr}",
        "format-icons": ["¾░ñ»", "¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
	    "on-click-right": "ghostty -e nmtui"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}´èö  {volume}%",
        "format-bluetooth-muted": "¾░ƒÄ ´èö  Mute",
        "format-muted": "¾░Øƒ  Mute",
        "format-icons": {
            "headphone": "¾░ïï ",
            "hands-free": "´ûÉ ",
            "headset": "´ûÉ ",
            "phone": "´éò ",
            "portable": "´éò ",
            "car": "´å╣ ",
            "default": ["¾░ò┐", "¾░ûÇ", "¾░ûÇ", "¾░ò¥"]
        },
        "on-click": "pamixer -t",
        "on-click-right": "pwvucontrol",
        "on-scroll-up": "pamixer -i 1",
        "on-scroll-down": "pamixer -d 1",
        "reverse-scrolling": true,
        "scroll-step": 0.5
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "´ä░  {volume}%",
        "format-source-muted": "´ä▒",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 2",
        "on-scroll-down": "pamixer --default-source -d 2",
        "scroll-step": 2,
        "tooltip": false
    },
    "custom/weather" : {
        // shows the current weather and forecast
        "tooltip" : true,
        "format" : "{}",
        "interval" : 30,
        "exec" : "~/.config/waybar/scripts/waybar-wttr.py",
        "return-type" : "json"
    },

    "custom/vpn": {
        "format": "VPN ´Çú",
        "exec": "echo '{\"class\": \"connected\"}'",
        "exec-if": "test -d /proc/sys/net/ipv4/conf/tun0",
        "return-type": "json",
        "interval": 5
    },
}

